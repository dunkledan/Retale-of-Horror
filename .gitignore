# ==========================
# Unreal Engine 5 .gitignore
# ==========================

# Visual Studio / IDE
.vs/
.vscode/
.idea/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.code-workspace

# OS files
.DS_Store
Thumbs.db

# Unreal generated folders
Binaries/
DerivedDataCache/
Intermediate/
Saved/

# Plugin generated folders
Plugins/*/Binaries/
Plugins/*/Intermediate/

# Ignore generated project files
*.xcodeproj
*.xcworkspace

# Generated build output
Build/**

# BUT keep important build metadata
!Build/
!Build/**/*.ico
!Build/**/*.png
!Build/**/*.rc
!Build/**/*.plist
!Build/**/*.entitlements
!Build/**/PakBlacklist*.txt

# Ignore packaged output
Releases/
Package/
Packages/

# Ignore cooked assets
Saved/Cooked/
Saved/StagedBuilds/

# Ignore autosaves and backups
Saved/Autosaves/
Saved/Backup/

# Ignore logs
Saved/Logs/

# Ignore crash reports
Saved/Crashes/

# Ignore local editor state
Saved/Config/WindowsEditor/
Saved/Config/LinuxEditor/
Saved/Config/MacEditor/

# Ignore local collections
Saved/Collections/

# Ignore Unreal cache
DerivedDataCache/**

# Ignore generated map lighting data (optional)
*_BuiltData.uasset

# Source art (optional)
SourceArt/**/*.psd
SourceArt/**/*.tga
SourceArt/**/*.png

# Compiled binaries
*.obj
*.o
*.dll
*.exe
*.so
*.dylib
*.lib
*.a
*.app

# Rider
.idea/

# JetBrains Rider UE
*.DotSettings.user

# Live Coding
*.patch
*.obj.response
LiveCodingModules.txt

# HLOD generated data (optional)
*_HLOD.uasset

# User-specific Unreal settings
Saved/Config/**

# Keep project defaults
!Config/

# Editor per-user settings
*.user
*.userprefs
*.tmp

# Visual Studio user settings
*.VC.db
*.VC.opendb
*.suo

# Rider / JetBrains
.idea/
*.DotSettings.user